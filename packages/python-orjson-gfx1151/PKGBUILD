pkgname=python-orjson-gfx1151
pkgver=3.11.8
pkgrel=1
pkgdesc='Fast, correct Python JSON library rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/ijl/orjson
license=(Apache-2.0 MIT)
depends=(glibc libgcc python-gfx1151)
makedepends=(cargo python-build python-installer python-maturin python-wheel rocm-llvm-gfx1151 rust)
optdepends=()
options=()
provides=(python-orjson)
conflicts=(python-orjson)
replaces=()
source=(https://files.pythonhosted.org/packages/source/o/orjson/orjson-3.11.8.tar.gz)
sha256sums=(SKIP)

build() {
  cd "$srcdir/orjson-3.11.8"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local _debug_prefix="/usr/src/debug/python-orjson-gfx1151"
  export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER="$CC"
  export RUSTFLAGS="-C target-cpu=znver5 -C opt-level=3 --remap-path-prefix=$srcdir=${_debug_prefix}"
  unset CFLAGS CXXFLAGS LDFLAGS

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/orjson-3.11.8"
  python -m installer --destdir="$pkgdir" dist/*.whl

  local _debug_prefix="/usr/src/debug/python-orjson-gfx1151"
  find "$pkgdir/usr/lib" -type f \( -name '*.so' -o -path '*/sboms/*.json' \) -print0 | while IFS= read -r -d '' _file; do
    sed -i       -e "s|$srcdir/orjson-3.11.8|${_debug_prefix}/orjson-3.11.8|g"       -e "s|$srcdir|${_debug_prefix}|g"       -e "s|/tmp/pkg/src/orjson-3.11.8|${_debug_prefix}/orjson-3.11.8|g"       "$_file" 2>/dev/null || true
  done
}
