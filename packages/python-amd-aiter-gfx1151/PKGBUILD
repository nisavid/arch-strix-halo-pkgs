pkgname=python-amd-aiter-gfx1151
pkgver=0.1.0.r8.d20260317.gad42886
pkgrel=7
pkgdesc='AMD AITER kernels rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/ROCm/aiter
license=(MIT)
depends=(python-gfx1151 python-pandas python-pytorch-opt-rocm-gfx1151 python-triton-gfx1151)
makedepends=(git python-build python-installer python-setuptools python-wheel rocm-llvm-gfx1151)
optdepends=('python-flydsl-gfx1151: optional FlyDSL MLIR kernels for AITER fused MoE paths (blocked on rocm-llvm MLIR Python SDK completeness)')
options=()
provides=(python-amd-aiter)
conflicts=(python-amd-aiter)
replaces=()
source=(aiter::git+https://github.com/ROCm/aiter.git 0001-gfx1151-rdna35-header-compat.patch 0002-jit-runtime-finds-hipcc-and-user-jit-modules.patch 0003-fused-moe-unknown-gfx-falls-back-to-2stage.patch 0004-moe-tuner-skips-missing-1stage-asm-metadata.patch 0005-ck-moe-normalizes-zero-splitk-and-forwards-stage2.patch)
sha256sums=(SKIP SKIP SKIP SKIP SKIP SKIP)

prepare() {
  cd "$srcdir/aiter"

  patch -Np1 -i "$srcdir/0001-gfx1151-rdna35-header-compat.patch"
  patch -Np1 -i "$srcdir/0002-jit-runtime-finds-hipcc-and-user-jit-modules.patch"
  patch -Np1 -i "$srcdir/0003-fused-moe-unknown-gfx-falls-back-to-2stage.patch"
  patch -Np1 -i "$srcdir/0004-moe-tuner-skips-missing-1stage-asm-metadata.patch"
  patch -Np1 -i "$srcdir/0005-ck-moe-normalizes-zero-splitk-and-forwards-stage2.patch"
}

build() {
  cd "$srcdir/aiter"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  export PATH="/opt/rocm/bin:${PATH}"
  export ROCM_HOME="/opt/rocm"
  export HIP_PATH="/opt/rocm"
  export PREBUILD_KERNELS=0
  export AITER_GPU_ARCH=gfx1151
  export CFLAGS="-O3 -march=native -famd-opt -Wno-error=unused-command-line-argument"
  export CXXFLAGS="-O3 -march=native -famd-opt -Wno-error=unused-command-line-argument"
  local _ck_submodule="$srcdir/aiter/3rdparty/composable_kernel"
  if [[ ! -d "${_ck_submodule}/include" ]]; then
    git submodule sync 3rdparty/composable_kernel
    git submodule update --init 3rdparty/composable_kernel
  fi
  [[ -d "${_ck_submodule}/example/ck_tile/01_fmha" ]] || {
    echo "CK submodule missing fmha codegen at ${_ck_submodule}" >&2
    return 1
  }
  export CK_DIR="${_ck_submodule}"

  mkdir -p dist
  pip wheel . --no-build-isolation --no-deps --wheel-dir dist -v
}

package() {
  cd "$srcdir/aiter"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
