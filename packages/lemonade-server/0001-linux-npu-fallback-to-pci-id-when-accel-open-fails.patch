+static std::string identify_npu_arch_from_pci_device(const fs::path& pci_path) {
+#ifdef __linux__
+    if (!fs::exists(pci_path) || !fs::is_directory(pci_path)) {
+        return "";
+    }
+
+    auto read_sysfs = [](const fs::path& p) {
+        std::ifstream is(p);
+        std::string s;
+        is >> s;
+        return s;
+    };
+
+    fs::path class_path = pci_path / "class";
+    fs::path vendor_path = pci_path / "vendor";
+    fs::path device_path = pci_path / "device";
+    fs::path revision_path = pci_path / "revision";
+    if (!fs::exists(class_path) || !fs::exists(vendor_path) || !fs::exists(device_path) || !fs::exists(revision_path)) {
+        return "";
+    }
+
+    if (read_sysfs(class_path) == "0x118000" && read_sysfs(vendor_path) == "0x1022" && read_sysfs(device_path) == "0x17f0") {
+        std::string revision = read_sysfs(revision_path);
+        if (revision == "0x10" || revision == "0x11" || revision == "0x20") {
+            return "XDNA2";
+        }
+    }
+#endif
+    return "";
+}
