+bool is_system_managed_external_backend(const std::string& recipe, const std::string& backend) {
+    if (recipe != "llamacpp") {
+        return false;
+    }
+    if (backend != "rocm" && backend != "vulkan") {
+        return false;
+    }
+    return !backends::BackendUtils::find_external_backend_binary(recipe, backend).empty();
+}
+
+std::string get_system_managed_backend_version_override(const std::string& recipe, const std::string& backend) {
+    if (recipe != "llamacpp") {
+        return "";
+    }
+    const char* version_env = nullptr;
+    if (backend == "rocm") {
+        version_env = std::getenv("LEMONADE_LLAMACPP_ROCM_VERSION");
+    } else if (backend == "vulkan") {
+        version_env = std::getenv("LEMONADE_LLAMACPP_VULKAN_VERSION");
+    }
+    return (version_env && *version_env) ? version_env : "";
+}
+
