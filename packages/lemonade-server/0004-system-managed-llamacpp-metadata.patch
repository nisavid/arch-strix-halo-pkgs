+        release_env = std::getenv("LEMONADE_LLAMACPP_ROCM_RELEASE_URL");
+    } else if (backend == "vulkan") {
+        release_env = std::getenv("LEMONADE_LLAMACPP_VULKAN_RELEASE_URL");
