package_rocm-core-gfx1151() {
    pkgdesc='ROCm core runtime files from TheRock for gfx1151'
    provides=('rocm-core')
    conflicts=('rocm-core' 'rocm-gfx1151-bin')
    depends=('gcc-libs' 'glibc' 'python-gfx1151' 'python-prettytable' 'python-pyelftools' 'python-yaml')
    _require_therock_root
    _copy_from_filelist 'rocm-core-gfx1151'
    install -d "${pkgdir}/opt/rocm/bin"
    ln -s ../libexec/rocm-core/rdhc.py "${pkgdir}/opt/rocm/bin/rdhc"
    install -Dm644 /dev/stdin "${pkgdir}/etc/ld.so.conf.d/rocm.conf" <<'EOF'
/opt/rocm/lib
EOF
    install -Dm644 /dev/stdin "${pkgdir}/etc/profile.d/rocm.sh" <<'EOF'
export ROCM_PATH=/opt/rocm
append_path '/opt/rocm/bin'
export PATH
EOF
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/fish/vendor_conf.d/rocm.fish" <<'EOF'
set --export --global ROCM_PATH /opt/rocm
fish_add_path --append --global /opt/rocm/bin
EOF
    install -Dm644 /dev/stdin "${pkgdir}/opt/rocm/share/doc/rocm-core/LICENSE.md" <<'EOF'
