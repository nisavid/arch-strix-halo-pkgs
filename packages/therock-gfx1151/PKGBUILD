package_rocm-opencl-runtime-gfx1151() {
    pkgdesc='ROCm OpenCL runtime from TheRock for gfx1151'
    provides=('rocm-opencl-runtime' 'rocm-ocl-icd' 'rocm-opencl-icd-loader' 'opencl-driver')
    conflicts=('rocm-gfx1151-bin' 'rocm-ocl-icd' 'rocm-opencl-icd-loader' 'rocm-opencl-runtime')
    depends=('rocm-core-gfx1151')
    _require_therock_root
    _copy_from_filelist 'rocm-opencl-runtime-gfx1151'
    install -Dm644 /dev/stdin "${pkgdir}/etc/OpenCL/vendors/amdocl64.icd" <<'EOF'
/opt/rocm/lib/libamdocl64.so
EOF
}

