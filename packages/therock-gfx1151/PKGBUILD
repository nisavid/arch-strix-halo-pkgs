_generated_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_require_therock_root() {
    if [[ ! -d "${_therock_root}/opt/rocm" ]]; then
        echo "THEROCK_ROOT_MISSING: ${_therock_root}/opt/rocm" >&2
        echo "HINT: set _THEROCK_ROOT to the staged filesystem root containing opt/rocm" >&2
        return 1
    fi
}

_copy_from_filelist() {
    local pkg="$1"
    local filelist="${_generated_root}/filelists/${pkg}.txt"
    [[ -f "${filelist}" ]] || { echo "FILELIST_MISSING: ${filelist}" >&2; return 1; }
    while IFS= read -r rel; do
        [[ -n "${rel}" ]] || continue
        mkdir -p "${pkgdir}/$(dirname "${rel}")"
        cp --parents -a "${_therock_root}/${rel}" "${pkgdir}"
    done < "${filelist}"
}

