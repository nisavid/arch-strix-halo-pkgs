package_rocm-smi-lib-gfx1151() {
    pkgdesc='ROCm SMI library from TheRock for gfx1151'
    provides=('rocm-smi-lib')
    conflicts=('rocm-gfx1151-bin' 'rocm-smi-lib')
    depends=('rocm-sysdeps-gfx1151')
    _require_therock_root
    _copy_from_filelist 'rocm-smi-lib-gfx1151'
    _rocm_smi_targets="${pkgdir}/opt/rocm/lib/cmake/rocm_smi/rocm_smiTargets.cmake"
    perl -0pi -e 's#/home/runner/_work/rockrel/rockrel/output/build/third-party/sysdeps/linux/libdrm/build/stage/lib/rocm_sysdeps/lib/pkgconfig/\.\./\.\./include/libdrm#\${_IMPORT_PREFIX}/lib/rocm_sysdeps/include/libdrm#g; s#/home/runner/_work/rockrel/rockrel/output/build/third-party/sysdeps/linux/libdrm/build/stage/lib/rocm_sysdeps/lib/pkgconfig/\.\./\.\./include#\${_IMPORT_PREFIX}/lib/rocm_sysdeps/include#g' "${_rocm_smi_targets}"
    perl -0pi -e 's#\$\{_IMPORT_PREFIX\}/\{OAM_NAME\}/include#\${_IMPORT_PREFIX}/include/oam#g' "${_rocm_smi_targets}"
}

