source=('torch_migraphx::git+https://github.com/ROCm/torch_migraphx.git#commit=6b2cd2237e83b675ae671650d08343dfbb0be5f3' 0001-import-pt2e-quantization-from-torchao.patch 0002-keep-dynamo-registration-lazy.patch 0003-relax-numpy-runtime-cap.patch 0004-preload-aot-autograd-before-native-extension.patch)
sha256sums=(SKIP SKIP SKIP SKIP SKIP)

prepare() {
  cd "$srcdir/torch_migraphx"

  if ! patch --dry-run -R -Np1 -i "$srcdir/0001-import-pt2e-quantization-from-torchao.patch" >/dev/null 2>&1; then
    patch -Np1 -i "$srcdir/0001-import-pt2e-quantization-from-torchao.patch"
  fi
  if ! patch --dry-run -R -Np1 -i "$srcdir/0002-keep-dynamo-registration-lazy.patch" >/dev/null 2>&1; then
    patch -Np1 -i "$srcdir/0002-keep-dynamo-registration-lazy.patch"
  fi
  if ! patch --dry-run -R -Np1 -i "$srcdir/0003-relax-numpy-runtime-cap.patch" >/dev/null 2>&1; then
    patch -Np1 -i "$srcdir/0003-relax-numpy-runtime-cap.patch"
  fi
  if ! patch --dry-run -R -Np1 -i "$srcdir/0004-preload-aot-autograd-before-native-extension.patch" >/dev/null 2>&1; then
    patch -Np1 -i "$srcdir/0004-preload-aot-autograd-before-native-extension.patch"
  fi
}

build() {
  cd "$srcdir/torch_migraphx/py"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  local _ccache_cache="$srcdir/.ccache/cache"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}" "${_ccache_cache}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_DIR="${CCACHE_DIR:-${_ccache_cache}}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  export CFLAGS="-O3 -march=native -mprefer-vector-width=512 -mavx512f -mavx512dq -mavx512vl -mavx512bw -Wno-error=unused-command-line-argument"
  export CXXFLAGS="${CFLAGS}"
  export ROCM_HOME=/opt/rocm
  export HIP_PATH=/opt/rocm
  export PYTORCH_ROCM_ARCH=gfx1151

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/torch_migraphx/py"

  python -m installer --destdir="$pkgdir" dist/*.whl

  local _site="$pkgdir/usr/lib/python3.14/site-packages"
  local _rpath='$ORIGIN:$ORIGIN/torch/lib:/opt/rocm/lib'
  patchelf --set-rpath "${_rpath}" "${_site}"/_torch_migraphx*.so
  install -Dm644 "$srcdir/torch_migraphx/LICENSE" \
    "$pkgdir/usr/share/licenses/python-torch-migraphx-gfx1151/LICENSE"
}
