license=(BSD-3-Clause)
depends=(gcc-libs glibc migraphx-gfx1151 python-gfx1151 python-numpy-gfx1151 python-packaging python-pytorch-opt-rocm-gfx1151 python-tabulate python-torchao-rocm-gfx1151)
