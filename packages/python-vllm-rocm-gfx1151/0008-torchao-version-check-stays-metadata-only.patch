--- /dev/null
+++ b/vllm/model_executor/layers/quantization/torchao_utils.py
@@ -0,0 +1,19 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+
+import importlib
+from importlib.util import find_spec
+
+from packaging import version
+
+
+def torchao_version_at_least(torchao_version: str) -> bool:
+    """Check installed torchao version without importing the torchao package."""
+    if find_spec("torchao"):
+        try:
+            installed_version = importlib.metadata.version("torchao")
+            if version.parse(installed_version) >= version.parse(torchao_version):
+                return True
+        except (ImportError, version.InvalidVersion):
+            return False
+    return False
