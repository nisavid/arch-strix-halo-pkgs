+@cache
+def rocm_flash_attn_supports_vllm_varlen_api() -> bool:
+    if not current_platform.is_rocm():
+        return True
+    if not _ROCM_FLASH_ATTN_AVAILABLE:
+        return False
+
+    try:
+        signature = inspect.signature(flash_attn_varlen_func)
+    except (TypeError, ValueError):
+        return False
+
+    required_keywords = {
+        "out",
+        "seqused_k",
+        "scheduler_metadata",
+        "fa_version",
+        "q_descale",
+        "k_descale",
+        "v_descale",
+        "num_splits",
+        "s_aux",
+        "return_softmax_lse",
+    }
+    parameters = signature.parameters
+    if any(
+        parameter.kind == inspect.Parameter.VAR_KEYWORD
+        for parameter in parameters.values()
+    ):
+        return True
+    return required_keywords.issubset(parameters)
+
