diff --git a/setup.py b/setup.py
index 0bbf165..94deff4 100644
--- a/setup.py
+++ b/setup.py
@@ -273,6 +273,19 @@ class cmake_build_ext(build_ext):
         elif _is_hip() and ROCM_HOME is not None:
             cmake_args += [f"-DROCM_PATH={ROCM_HOME}"]
 
+        # setuptools environment flags are not forwarded into the ROCm/HIP
+        # CMake lane automatically. Pass them through explicitly so distro
+        # sanitization flags (prefix maps) and host tuning flags reach both the
+        # host C/C++ and HIP extension builds.
+        for env_name, cmake_name in (
+            ("CFLAGS", "CMAKE_C_FLAGS"),
+            ("CXXFLAGS", "CMAKE_CXX_FLAGS"),
+            ("HIPFLAGS", "CMAKE_HIP_FLAGS"),
+        ):
+            env_value = os.environ.get(env_name)
+            if env_value:
+                cmake_args += [f"-D{cmake_name}={env_value}"]
+
         other_cmake_args = os.environ.get("CMAKE_ARGS")
         if other_cmake_args:
             cmake_args += other_cmake_args.split()
