@@ -249,6 +249,14 @@ def apply_top_k_top_p(
     if p is None and k is None:
         return logits
 
+    if current_platform.is_rocm():
+        # Use PyTorch top-k/top-p filtering on ROCm. The Triton filter path
+        # can fault on gfx1151 for large Qwen3.5-family vocabularies; a
