+def _should_load_benchmark_module() -> bool:
+    if len(sys.argv) < 2:
+        return False
+
+    first_arg = sys.argv[1]
+    return first_arg == "bench" or first_arg.startswith("bench=")
+
+
+class _BenchHelpSubcommand:
+    name = "bench"
+    help = "vLLM bench subcommand."
+
