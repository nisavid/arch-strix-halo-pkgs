+def _maybe_pad_intermediate_for_aiter(
+    w13_weight: torch.Tensor,
+    w2_weight: torch.Tensor,
+    moe_config: "FusedMoEConfig",
+) -> tuple[torch.Tensor, torch.Tensor]:
+    """Pad the MoE intermediate dimension to a multiple of 128 for AITER CK GEMM compatibility.
+
+    Some models (for example Gemma 4 26B-A4B with
+    ``expert_intermediate_size=704``) have intermediate sizes that are not
+    aligned to CK's device_gemm tile requirements, which makes the ROCm AITER
+    fused-MoE path reject the problem shape at runtime.
+
+    Zero-padding is mathematically safe here: the extra ``w13`` outputs are
+    zero, gated activations preserve those zeros, and the extra ``w2`` input
+    columns are also zero.
+    """
+    aiter_moe_align = 128
+    intermediate = w2_weight.shape[-1]
+    padded_intermediate = (
+        (intermediate + aiter_moe_align - 1) // aiter_moe_align
+    ) * aiter_moe_align
+    if padded_intermediate == intermediate:
+        return w13_weight, w2_weight
+
+    pad_amount = padded_intermediate - intermediate
+    logger.info_once(
+        "Padding MoE intermediate dimension from %d to %d for AITER CK GEMM alignment.",
+        intermediate,
+        padded_intermediate,
+    )
+
+    if moe_config.is_act_and_mul:
+        gate, up = w13_weight.data.chunk(2, dim=1)
+        gate = F.pad(gate, (0, 0, 0, pad_amount))
+        up = F.pad(up, (0, 0, 0, pad_amount))
+        w13_padded = torch.cat([gate, up], dim=1).contiguous()
+    else:
+        w13_padded = F.pad(w13_weight.data, (0, 0, 0, pad_amount)).contiguous()
+
+    w2_padded = F.pad(w2_weight.data, (0, pad_amount)).contiguous()
+
+    if padded_intermediate != moe_config.intermediate_size_per_partition:
+        moe_config.intermediate_size_per_partition = padded_intermediate
+
+    torch.accelerator.empty_cache()
+
+    return (
+        Parameter(w13_padded, requires_grad=False),
+        Parameter(w2_padded, requires_grad=False),
+    )
+
+
