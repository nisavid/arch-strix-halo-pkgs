pkgname=python-safetensors-gfx1151
pkgver=0.7.0
pkgrel=1
pkgdesc='Safe tensor serialization format rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/huggingface/safetensors
license=(Apache-2.0)
depends=(glibc libgcc python-gfx1151 python-numpy-gfx1151)
makedepends=(cargo python-build python-installer python-maturin python-wheel rocm-llvm-gfx1151 rust)
optdepends=('python-jax: usage with jax' 'python-pytorch-opt-rocm-gfx1151: usage with the local PyTorch lane' 'python-tensorflow: usage with tensorflow')
options=()
provides=(python-safetensors)
conflicts=(python-safetensors)
replaces=()
source=(https://files.pythonhosted.org/packages/source/s/safetensors/safetensors-0.7.0.tar.gz)
sha256sums=(07663963b67e8bd9f0b8ad15bb9163606cd27cc5a1b96235a50d8369803b96b0)

build() {
  cd "$srcdir/safetensors-0.7.0"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  local _ccache_cache="$srcdir/.ccache/cache"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}" "${_ccache_cache}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="$srcdir"
    export CCACHE_DIR="${_ccache_cache}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local _debug_prefix="/usr/src/debug/python-safetensors-gfx1151"
  export CARGO_HOME="$srcdir/.cargo"
  mkdir -p "$CARGO_HOME"
  export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER="$CC"
  export RUSTFLAGS="-C target-cpu=znver5 -C opt-level=3 --remap-path-prefix=$srcdir=${_debug_prefix}"
  unset CFLAGS CXXFLAGS LDFLAGS

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/safetensors-0.7.0"
  python -m installer --destdir="$pkgdir" dist/*.whl

  local _debug_prefix="/usr/src/debug/python-safetensors-gfx1151"
  find "$pkgdir/usr/lib" -type f -path '*/sboms/*.json' -print0 | while IFS= read -r -d '' _file; do
    sed -i       -e "s|$srcdir/safetensors-0.7.0|${_debug_prefix}/safetensors-0.7.0|g"       -e "s|$srcdir|${_debug_prefix}|g"       -e "s|/tmp/pkg/src/safetensors-0.7.0|${_debug_prefix}/safetensors-0.7.0|g"       "$_file" 2>/dev/null || true
  done
}
