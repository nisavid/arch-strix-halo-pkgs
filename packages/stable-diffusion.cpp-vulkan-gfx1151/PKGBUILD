pkgname=stable-diffusion.cpp-vulkan-gfx1151
pkgver=r593.g3d6064b
pkgrel=1
pkgdesc='stable-diffusion.cpp Vulkan backend rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/leejet/stable-diffusion.cpp
license=(MIT)
depends=(aocl-libm-gfx1151 gcc-libs glibc vulkan-icd-loader)
makedepends=(cmake git ninja patchelf rocm-llvm-gfx1151 shaderc spirv-headers vulkan-headers)
optdepends=()
options=()
provides=(stable-diffusion.cpp-vulkan-gfx1151 stable-diffusion.cpp-vulkan)
conflicts=(stable-diffusion.cpp-vulkan)
