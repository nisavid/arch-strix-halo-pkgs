pkgname=python-torchao-rocm-gfx1151
pkgver=0.17.0
pkgrel=2
pkgdesc='Package for applying ao techniques to GPU models with ROCm, rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/pytorch/ao
license=(BSD-3-Clause)
depends=(glibc python-gfx1151 python-pytorch-opt-rocm-gfx1151)
makedepends=(cmake git ninja patchelf python-build python-installer python-setuptools python-wheel python-pytorch-opt-rocm-gfx1151 rocm-llvm-gfx1151)
optdepends=()
options=()
provides=(python-torchao python-torchao-rocm)
conflicts=(python-torchao python-torchao-rocm)
replaces=()
source=('torchao::git+https://github.com/pytorch/ao.git#tag=v0.17.0' 0001-setup.py-honor-pytorch-rocm-arch.patch 0002-python-3.14-pt2e-union-aliases.patch)
sha256sums=(SKIP SKIP SKIP)

prepare() {
  cd "$srcdir/torchao"

  if [[ ! -d third_party/cutlass/include ]]; then
    git submodule sync --recursive
    git submodule update --init --recursive
  fi
  if ! patch --dry-run -R -Np1 -i "$srcdir/0001-setup.py-honor-pytorch-rocm-arch.patch" >/dev/null 2>&1; then
    patch -Np1 -i "$srcdir/0001-setup.py-honor-pytorch-rocm-arch.patch"
  fi
  if ! patch --dry-run -R -Np1 -i "$srcdir/0002-python-3.14-pt2e-union-aliases.patch" >/dev/null 2>&1; then
    patch -Np1 -i "$srcdir/0002-python-3.14-pt2e-union-aliases.patch"
  fi
}

build() {
  cd "$srcdir/torchao"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local _base_flags="-O3 -march=native -mprefer-vector-width=512 -mavx512f -mavx512dq -mavx512vl -mavx512bw -mllvm -enable-gvn-hoist -mllvm -enable-gvn-sink -famd-opt -Wno-error=unused-command-line-argument"
  local _wheel_flags
  _wheel_flags="$(printf '%s' "${_base_flags}" | sed -E 's/-mllvm (-[^ ]+)/-Xclang -mllvm -Xclang \1/g; s/-famd-opt//g; s/  +/ /g; s/^ +| +$//g')"

  export CFLAGS="${_wheel_flags}"
  export CXXFLAGS="${_wheel_flags}"
  export LDFLAGS="-famd-opt"
  export ROCM_HOME=/opt/rocm
  export PYTORCH_ROCM_ARCH=gfx1151
  export VERSION_SUFFIX=

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/torchao"
  python -m installer --destdir="$pkgdir" dist/*.whl

  local _rpath='$ORIGIN:$ORIGIN/../torch/lib:/opt/rocm/lib'
  local _so
  shopt -s nullglob
  for _so in "$pkgdir"/usr/lib/python3.14/site-packages/torchao/_C*.so; do
    patchelf --set-rpath "${_rpath}" "${_so}"
  done
  shopt -u nullglob
}
