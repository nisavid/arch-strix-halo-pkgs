From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Strix Halo Packaging <packaging@example.invalid>
Date: Sat, 25 Apr 2026 00:00:00 +0000
Subject: [PATCH] Disable Werror with TheRock LLVM headers

The package uses the ROCm Triton fork with its own compatible LLVM lane, but
the build still sees warning shapes that should not fail the package build.
---
 CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 91d9cbf..8fc0f94 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -97,7 +97,7 @@ function(add_triton_plugin name)
 endfunction()
 
 # Disable warnings that show up in external code (gtest;pybind11)
-set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -Werror -Wno-covered-switch-default -fvisibility=hidden")
+set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -Wno-covered-switch-default -fvisibility=hidden")
 
 include_directories(".")
 include_directories(${MLIR_INCLUDE_DIRS})
