pkgname=python-triton-gfx1151
pkgver=3.0.0+git0ec280cf
pkgrel=1
pkgdesc='Language and compiler for custom deep-learning primitives, rebuilt from the ROCm performance fork for Strix Halo gfx1151'
arch=('x86_64')
url=https://triton-lang.org/main/index.html
license=(MIT)
depends=(glibc libgcc python-gfx1151)
makedepends=(cmake git ninja pybind11 python-build python-installer python-setuptools python-wheel)
optdepends=()
options=()
provides=(python-triton=3.0.0+git0ec280cf)
conflicts=(python-triton)
replaces=()
source=('triton::git+https://github.com/ROCm/triton.git#commit=0ec280cf80dd91e9a86887981a670f2d4541a32b' 0001-python-3.14-and-pybind11-build-system.patch 0002-disable-werror-with-therock-llvm-headers.patch 0003-attrs-descriptor-repr-for-inductor.patch)
sha256sums=(SKIP SKIP SKIP SKIP)

prepare() {
  cd "$srcdir/triton"

  patch -Np1 -i "$srcdir/0001-python-3.14-and-pybind11-build-system.patch"
  patch -Np1 -i "$srcdir/0002-disable-werror-with-therock-llvm-headers.patch"
  patch -Np1 -i "$srcdir/0003-attrs-descriptor-repr-for-inductor.patch"
}

build() {
  cd "$srcdir/triton/python"
  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  export ROCM_HOME="/opt/rocm"
  export ROCM_PATH="/opt/rocm"
  unset LLVM_SYSPATH
  export TRITON_BUILD_PROTON=OFF
  if command -v ccache >/dev/null 2>&1; then
    export TRITON_BUILD_WITH_CCACHE=true
  else
    unset TRITON_BUILD_WITH_CCACHE
  fi

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/triton/python"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 "$srcdir/triton/LICENSE" "$pkgdir/usr/share/licenses/python-triton-gfx1151/LICENSE"
}
