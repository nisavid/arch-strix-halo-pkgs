From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: nisavid <nisavid@users.noreply.github.com>
Date: Thu, 23 Apr 2026 07:58:00 -0400
Subject: [PATCH] gate CK varlen paged-KV on split-KV codegen

The bounded gfx1151 CK package can omit split-KV generated kernels. Reject the
paged-KV block-table path only when FLASH_ATTENTION_CK_HAS_SPLITKV is absent,
and compile the split-KV branch when setup.py defines that macro.
---
 csrc/flash_attn_ck/mha_varlen_fwd.cpp | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/csrc/flash_attn_ck/mha_varlen_fwd.cpp b/csrc/flash_attn_ck/mha_varlen_fwd.cpp
index 0f33527b..604b43b6 100644
--- a/csrc/flash_attn_ck/mha_varlen_fwd.cpp
+++ b/csrc/flash_attn_ck/mha_varlen_fwd.cpp
@@ -385,6 +385,9 @@ mha_varlen_fwd(at::Tensor &q,                   // total_q x num_heads x head_si
 
     at::Tensor block_table;
     const bool paged_KV = block_table_.has_value();
+#ifndef FLASH_ATTENTION_CK_HAS_SPLITKV
+    TORCH_CHECK(!paged_KV, "CK build does not include generated split-KV kernels");
+#endif
     if (paged_KV) {
         block_table = block_table_.value();
         CHECK_DEVICE(block_table);
@@ -492,6 +496,7 @@ mha_varlen_fwd(at::Tensor &q,                   // total_q x num_heads x head_si
 #endif
         ck_tile::stream_config stream_config{stream};
 
+#ifdef FLASH_ATTENTION_CK_HAS_SPLITKV
         if (paged_KV)
         {
             auto traits =
@@ -532,6 +537,7 @@ mha_varlen_fwd(at::Tensor &q,                   // total_q x num_heads x head_si
             float t = fmha_fwd_splitkv(traits, args, stream_config);
             TORCH_CHECK(t >= 0, "invalid argument for fmha_fwd_splitkv");
         }
         else
+#endif
         {
             auto drop_seed_offset = std::make_pair(rng_state_ptr, rng_state_ptr + 1);
-- 
2.51.0
