# Maintainer: nisavid
# Package experiment for ROCm FlashAttention CK plus Triton backend access on gfx1151

pkgname=python-flash-attn-rocm-gfx1151
pkgver=2.8.4
pkgrel=10
pkgdesc='FlashAttention ROCm CK backend experiment for the local gfx1151 stack'
arch=('x86_64')
url=https://github.com/ROCm/flash-attention
license=(BSD-3-Clause)
depends=(python-amd-aiter-gfx1151 python-einops python-gfx1151 python-pytorch-opt-rocm-gfx1151 python-triton-gfx1151)
makedepends=(git ninja python-installer python-packaging python-pip python-psutil python-setuptools python-wheel)
optdepends=('python-vllm-rocm-gfx1151: local engine probe candidate after direct flash_attn smoke passes')
options=(!lto)
provides=(python-flash-attn python-flash-attention)
conflicts=(python-flash-attn python-flash-attention)
replaces=()
source=('flash-attention::git+https://github.com/ROCm/flash-attention.git#commit=3f94643fb41bcedded28c85185a8e11d42ef1592'
        0001-skip-bundled-aiter-install.patch
        0002-import-amdsmi-before-torch.patch
        0003-use-system-triton-package.patch
        0004-enable-gfx1151-ck-codegen.patch
        0005-preserve-packaged-ck-submodule-checkout.patch
        0006-limit-ck-smoke-build-to-forward-d32.patch
        0007-adapt-ck-fwd-args-layout.patch
        0008-disable-ck-varlen-paged-kv-in-forward-smoke.patch
        0009-accept-vllm-varlen-wrapper-keywords.patch)
sha256sums=(SKIP SKIP SKIP SKIP SKIP SKIP SKIP SKIP SKIP SKIP)

prepare() {
  cd "$srcdir/flash-attention"

  git reset --hard 3f94643fb41bcedded28c85185a8e11d42ef1592
  git clean -fdx

  for _patch in \
    0001-skip-bundled-aiter-install.patch \
    0002-import-amdsmi-before-torch.patch \
    0003-use-system-triton-package.patch \
    0004-enable-gfx1151-ck-codegen.patch \
    0005-preserve-packaged-ck-submodule-checkout.patch \
    0006-limit-ck-smoke-build-to-forward-d32.patch \
    0007-adapt-ck-fwd-args-layout.patch \
    0008-disable-ck-varlen-paged-kv-in-forward-smoke.patch \
    0009-accept-vllm-varlen-wrapper-keywords.patch; do
    if ! patch --dry-run -R -Np1 -i "$srcdir/${_patch}" >/dev/null 2>&1; then
      patch -Np1 -i "$srcdir/${_patch}"
    fi
  done

  local _ck_commit=03ce21ddcbb75c5ac8630628a913d0b2ced4979a
  git submodule update --init csrc/composable_kernel
  git -C csrc/composable_kernel fetch origin "${_ck_commit}"
  git -C csrc/composable_kernel checkout "${_ck_commit}"
}

build() {
  cd "$srcdir/flash-attention"

  export FLASH_ATTENTION_TRITON_AMD_ENABLE=FALSE
  export FLASH_ATTENTION_SKIP_CUDA_BUILD=FALSE
  export FLASH_ATTENTION_FORCE_BUILD=TRUE
  export FLASH_ATTENTION_CK_GENERATORS=fwd,fwd_splitkv
  export FLASH_ATTENTION_CK_FILTER='*fp16*nbias_nmask*ndropout*'
  export FLASH_ATTENTION_CK_NO_BWD_KVCACHE_API=TRUE
  export GPU_ARCHS=gfx1151
  export OPT_DIM=32,256
  export ROCM_HOME=/opt/rocm
  export HIP_PATH=/opt/rocm

  mkdir -p dist
  rm -f dist/*.whl
  pip wheel . --no-build-isolation --no-deps --wheel-dir dist -v
}

package() {
  cd "$srcdir/flash-attention"

  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/python-flash-attn-rocm-gfx1151/LICENSE"
}
