From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: nisavid <nisavid@users.noreply.github.com>
Date: Thu, 23 Apr 2026 02:20:00 -0400
Subject: [PATCH] limit CK build to forward generators

The full CK backend emits thousands of generated HIP translation units. For
the local gfx1151 experiment, allow the package to request only selected CK
forward generator blobs and guard the pybind API so import and forward calls
do not refer to omitted backward or fwd_kvcache symbols. Keep both fixed-length
and variable-length forward entrypoints because vLLM's FLASH_ATTN consumer
path uses flash_attn_varlen_func, define split-KV support when that generated
surface is requested, keep the bounded filter only on plain fwd generation,
and clear stale generated build output before each codegen pass.
---
 csrc/flash_attn_ck/flash_api.cpp |  8 ++++++++
 setup.py                         | 59 +++++++++++++++++++++++++++++++-------
 2 files changed, 52 insertions(+), 15 deletions(-)

diff --git a/csrc/flash_attn_ck/flash_api.cpp b/csrc/flash_attn_ck/flash_api.cpp
index a0580d52..1f327691 100644
--- a/csrc/flash_attn_ck/flash_api.cpp
+++ b/csrc/flash_attn_ck/flash_api.cpp
@@ -40,7 +40,8 @@ mha_varlen_fwd(at::Tensor &q,                               // total_q x num_hea
                const float softcap,
                const bool return_softmax,
                std::optional<at::Generator> gen_);
 
+#ifndef FLASH_ATTENTION_CK_NO_BWD_KVCACHE_API
 std::vector<at::Tensor>
 mha_bwd(const at::Tensor &dout,                   // batch_size x seqlen_q x num_heads, x multiple_of(head_size_og, 8)
         const at::Tensor &q,                      // batch_size x seqlen_q x num_heads x head_size
@@ -110,13 +111,15 @@ mha_fwd_kvcache(at::Tensor &q,
                 const float softcap,
                 bool is_rotary_interleaved, // if true, rotary combines indices 0 & 1, else indices 0 & rotary_dim / 2
                 int num_splits);
-
+#endif
 PYBIND11_MODULE(TORCH_EXTENSION_NAME, m)
 {
         m.doc() = "FlashAttention";
         m.def("fwd", &mha_fwd, "Forward pass");
         m.def("varlen_fwd", &mha_varlen_fwd, "Forward pass (variable length)");
+#ifndef FLASH_ATTENTION_CK_NO_BWD_KVCACHE_API
         m.def("bwd", &mha_bwd, "Backward pass");
         m.def("varlen_bwd", &mha_varlen_bwd, "Backward pass (variable length)");
         m.def("fwd_kvcache", &mha_fwd_kvcache, "Forward pass, with KV-cache");
+#endif
 }
diff --git a/setup.py b/setup.py
index 3bf4a90..c6fe093 100644
--- a/setup.py
+++ b/setup.py
@@ -393,14 +393,38 @@ elif not SKIP_CUDA_BUILD and IS_ROCM:
         ck_dir = "csrc/composable_kernel"

         #use codegen get code dispatch
-        if not os.path.exists("./build"):
-            os.makedirs("build")
+        if os.path.exists("./build"):
+            shutil.rmtree("build")
+        os.makedirs("build")

         optdim = os.getenv("OPT_DIM", "32,64,128,256")
-        subprocess.run([sys.executable, f"{ck_dir}/example/ck_tile/01_fmha/generate.py", "-d", "fwd", "--output_dir", "build", "--receipt", "2", "--optdim", optdim], check=True)
-        subprocess.run([sys.executable, f"{ck_dir}/example/ck_tile/01_fmha/generate.py", "-d", "fwd_appendkv", "--output_dir", "build", "--receipt", "2", "--optdim", optdim], check=True)
-        subprocess.run([sys.executable, f"{ck_dir}/example/ck_tile/01_fmha/generate.py", "-d", "fwd_splitkv", "--output_dir", "build", "--receipt", "2", "--optdim", optdim], check=True)
-        subprocess.run([sys.executable, f"{ck_dir}/example/ck_tile/01_fmha/generate.py", "-d", "bwd", "--output_dir", "build", "--receipt", "2", "--optdim", optdim], check=True)
+        codegen_targets = set()
+        for a in os.getenv("GPU_ARCHS", "native").split(";"):
+            if a == "native":
+                continue
+            if a.startswith("gfx9"):
+                codegen_targets.add("gfx9")
+            elif a.startswith("gfx11"):
+                codegen_targets.add("gfx11")
+            elif a.startswith("gfx12"):
+                codegen_targets.add("gfx12")
+        targets_arg = ["--targets", ",".join(sorted(codegen_targets))] if codegen_targets else []
+        ck_generators = [
+            item.strip()
+            for item in os.getenv("FLASH_ATTENTION_CK_GENERATORS", "fwd,fwd_appendkv,fwd_splitkv,bwd").split(",")
+            if item.strip()
+        ]
+        valid_ck_generators = {"fwd", "fwd_appendkv", "fwd_splitkv", "bwd"}
+        assert set(ck_generators) <= valid_ck_generators, (
+            f"Unsupported FLASH_ATTENTION_CK_GENERATORS entries: {ck_generators}"
+        )
+        gen_common = [sys.executable, f"{ck_dir}/example/ck_tile/01_fmha/generate.py", "--output_dir", "build", "--receipt", "2", "--optdim", optdim] + targets_arg
+        ck_filter = os.getenv("FLASH_ATTENTION_CK_FILTER")
+        for ck_generator in ck_generators:
+            gen_args = list(gen_common)
+            if ck_generator == "fwd" and ck_filter:
+                gen_args += ["--filter", ck_filter]
+            subprocess.run(gen_args + ["-d", ck_generator], check=True)
 
         # Check, if ATen/CUDAGeneratorImpl.h is found, otherwise use ATen/cuda/CUDAGeneratorImpl.h
         # See https://github.com/pytorch/pytorch/pull/70650
@@ -425,15 +449,14 @@ elif not SKIP_CUDA_BUILD and IS_ROCM:
         if FORCE_CXX11_ABI:
             torch._C._GLIBCXX_USE_CXX11_ABI = True
 
-        sources = ["csrc/flash_attn_ck/flash_api.cpp",
-                "csrc/flash_attn_ck/flash_common.cpp",
-                "csrc/flash_attn_ck/mha_bwd.cpp",
-                "csrc/flash_attn_ck/mha_fwd_kvcache.cpp",
-                "csrc/flash_attn_ck/mha_fwd.cpp",
-                "csrc/flash_attn_ck/mha_varlen_bwd.cpp",
-                "csrc/flash_attn_ck/mha_varlen_fwd.cpp"] + glob.glob(
-            f"build/fmha_*wd*.cpp"
-        )
+        sources = ["csrc/flash_attn_ck/flash_api.cpp", "csrc/flash_attn_ck/flash_common.cpp"]
+        if "fwd" in ck_generators:
+            sources += ["csrc/flash_attn_ck/mha_fwd.cpp", "csrc/flash_attn_ck/mha_varlen_fwd.cpp"]
+        if "fwd_appendkv" in ck_generators:
+            sources += ["csrc/flash_attn_ck/mha_fwd_kvcache.cpp"]
+        if "bwd" in ck_generators:
+            sources += ["csrc/flash_attn_ck/mha_bwd.cpp", "csrc/flash_attn_ck/mha_varlen_bwd.cpp"]
+        sources += glob.glob(f"build/fmha_*wd*.cpp")
 
         # Check if torch is using hipify v2. Until CK is updated with HIPIFY_V2 macro,
         # we must replace the incorrect APIs.
@@ -443,13 +466,17 @@ elif not SKIP_CUDA_BUILD and IS_ROCM:
 
         rename_cpp_to_cu(sources)
 
-        renamed_sources = ["csrc/flash_attn_ck/flash_api.cu",
-                        "csrc/flash_attn_ck/flash_common.cu",
-                        "csrc/flash_attn_ck/mha_bwd.cu",
-                        "csrc/flash_attn_ck/mha_fwd_kvcache.cu",
-                        "csrc/flash_attn_ck/mha_fwd.cu",
-                        "csrc/flash_attn_ck/mha_varlen_bwd.cu",
-                        "csrc/flash_attn_ck/mha_varlen_fwd.cu"] + glob.glob(f"build/fmha_*wd*.cu")
+        renamed_sources = [
+            source[:-4] + ".cu" if source.endswith(".cpp") else source
+            for source in sources
+        ]
+
+        ck_api_flag = []
+        if os.getenv("FLASH_ATTENTION_CK_NO_BWD_KVCACHE_API", "FALSE") == "TRUE":
+            ck_api_flag = ["-DFLASH_ATTENTION_CK_NO_BWD_KVCACHE_API"]
+        ck_splitkv_flag = []
+        if "fwd_splitkv" in ck_generators:
+            ck_splitkv_flag = ["-DFLASH_ATTENTION_CK_HAS_SPLITKV"]
 
         cc_flag += ["-O3","-std=c++20",
                     "-DCK_TILE_FMHA_FWD_FAST_EXP2=1",
@@ -465,6 +492,7 @@ elif not SKIP_CUDA_BUILD and IS_ROCM:
                     "-DUSE_PROF_API=1",
                     # "-DFLASHATTENTION_DISABLE_BACKWARD",
                     "-D__HIP_PLATFORM_HCC__=1"]
+        cc_flag += ck_api_flag + ck_splitkv_flag
 
         cc_flag += [f"-DCK_TILE_FLOAT_TO_BFLOAT16_DEFAULT={os.environ.get('CK_TILE_FLOAT_TO_BFLOAT16_DEFAULT', 3)}"]
 
@@ -483,7 +511,7 @@ elif not SKIP_CUDA_BUILD and IS_ROCM:
             cc_flag += ["-mllvm", "-amdgpu-coerce-illegal-types=1"]
 
         extra_compile_args = {
-            "cxx": ["-O3", "-std=c++20"] + generator_flag + maybe_hipify_v2_flag,
+            "cxx": ["-O3", "-std=c++20"] + generator_flag + maybe_hipify_v2_flag + ck_api_flag + ck_splitkv_flag,
             "nvcc": cc_flag + generator_flag + maybe_hipify_v2_flag,
         }
 
-- 
