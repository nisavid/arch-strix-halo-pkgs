pkgname=python-pydantic-core-gfx1151
pkgver=2.41.5
pkgrel=1
pkgdesc='Core validation logic for pydantic rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/pydantic/pydantic-core
license=(MIT)
depends=(glibc libgcc python-gfx1151 python-typing-inspection python-typing_extensions)
makedepends=(cargo python-build python-installer python-maturin python-wheel rocm-llvm-gfx1151 rust)
optdepends=()
options=()
provides=(python-pydantic-core)
conflicts=(python-pydantic-core)
replaces=()
source=(https://files.pythonhosted.org/packages/source/p/pydantic_core/pydantic_core-2.41.5.tar.gz)
sha256sums=(08daa51ea16ad373ffd5e7606252cc32f07bc72b28284b6bc9c6df804816476e)

build() {
  cd "$srcdir/pydantic_core-2.41.5"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  local _ccache_cache="$srcdir/.ccache/cache"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}" "${_ccache_cache}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="$srcdir"
    export CCACHE_DIR="${_ccache_cache}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local _debug_prefix="/usr/src/debug/python-pydantic-core-gfx1151"
  export CARGO_HOME="$srcdir/.cargo"
  mkdir -p "$CARGO_HOME"
  export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER="$CC"
  export RUSTFLAGS="-C target-cpu=znver5 -C opt-level=3 --remap-path-prefix=$srcdir=${_debug_prefix}"
  unset CFLAGS CXXFLAGS LDFLAGS

  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/pydantic_core-2.41.5"
  python -m installer --destdir="$pkgdir" dist/*.whl

  local _debug_prefix="/usr/src/debug/python-pydantic-core-gfx1151"
  find "$pkgdir/usr/lib" -type f -path '*/sboms/*.json' -print0 | while IFS= read -r -d '' _file; do
    sed -i       -e "s|$srcdir/pydantic_core-2.41.5|${_debug_prefix}/pydantic_core-2.41.5|g"       -e "s|$srcdir|${_debug_prefix}|g"       -e "s|/tmp/pkg/src/pydantic_core-2.41.5|${_debug_prefix}/pydantic_core-2.41.5|g"       "$_file" 2>/dev/null || true
  done
}
