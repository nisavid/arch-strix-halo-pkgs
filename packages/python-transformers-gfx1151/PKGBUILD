# Maintainer: nisavid

pkgname=python-transformers-gfx1151
pkgver=5.7.0
pkgrel=2
pkgdesc='State-of-the-art pretrained models for inference and training rebuilt for Strix Halo gfx1151'
arch=('any')
url='https://github.com/huggingface/transformers'
license=(Apache-2.0)
depends=(
  python-gfx1151
  python-huggingface-hub
  python-numpy-gfx1151
  python-packaging
  python-regex
  python-safetensors-gfx1151
  python-tokenizers-gfx1151
  python-tqdm
  python-typer
  python-pyyaml-gfx1151
)
makedepends=(
  python-build
  python-installer
  python-setuptools
  python-wheel
)
optdepends=(
  'python-bitsandbytes: 8-bit support for PyTorch'
  'python-keras: support for models in Keras 3'
  'python-pytorch-opt-rocm-gfx1151: PyTorch support on the local ROCm lane'
)
options=()
provides=(python-transformers)
conflicts=(python-transformers)
replaces=()
source=(https://files.pythonhosted.org/packages/source/t/transformers/transformers-5.7.0.tar.gz)
sha256sums=(SKIP)

build() {
  cd "$srcdir/transformers-5.7.0"
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/transformers-5.7.0"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
