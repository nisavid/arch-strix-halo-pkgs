pkgname=python-aotriton-gfx1151
pkgver=0.11.2b
pkgrel=2
pkgdesc='Ahead-of-time Triton math library rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/ROCm/aotriton
license=(MIT)
depends=(gcc-libs glibc hip-runtime-amd-gfx1151 hipsparselt-gfx1151 python-gfx1151 python-triton-gfx1151 rocm-core-gfx1151)
makedepends=(cmake git ninja pybind11 python-filelock python-iniconfig python-msgpack python-numpy-gfx1151 python-packaging python-pandas python-pluggy python-setuptools python-wheel python-pyyaml-gfx1151 rocm-llvm-gfx1151)
optdepends=()
options=()
provides=(python-aotriton=0.11.2b)
conflicts=(python-aotriton)
