pkgname=aocl-libm-gfx1151
pkgver=5.2.2.r8.d20260317.gad42886
pkgrel=1
pkgdesc='AMD AOCL-LibM rebuilt with Zen 5 tuning for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/amd/aocl-libm-ose.git
license=(BSD-3-Clause MIT Apache-2.0)
depends=(aocl-utils-gfx1151 gcc-libs glibc)
makedepends=(git patchelf python rocm-llvm-gfx1151 scons)
optdepends=()
options=()
provides=(aocl-libm)
conflicts=(aocl-libm)
