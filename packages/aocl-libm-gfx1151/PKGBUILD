sha256sums=(SKIP)

prepare() {
  cd "$srcdir/aocl-libm"

# Remove -muse-unaligned-vector-move flag. This is AOCC-only; TheRock's open-source amdclang doesn't support it. The -famd-opt flag covers equivalent optimizations.

    if grep -Fq muse-unaligned-vector-move src/SConscript; then
      sed -i 's/ccflags.append('"'"'-muse-unaligned-vector-move'"'"')/pass  # patched: AOCC-only flag removed for amdclang/' src/SConscript
    fi
    # Add -Wno-macro-redefined to suppress CMPLX/CMPLXF macro redefinition warnings. These macros are defined in both AOCL-LibM headers and glibc complex.h.

    if ! grep -Fq Wno-macro-redefined src/SConscript; then
      sed -i 's/'"'"'-Werror'"'"'/'"'"'-Werror'"'"', '"'"'-Wno-macro-redefined'"'"'/' src/SConscript
    fi
    # Fix linker flags: -ealm_main is AOCC syntax, use -Wl,-e,alm_main for GCC/Clang. Add -fuse-ld=bfd because hand-written AVX assembly uses absolute relocations that lld rejects in shared libraries; GNU ld handles them via dynamic text relocations.

    if grep -Fq ''"'"'-ealm_main'"'"'' src/SConscript; then
      sed -i 's|'"'"'-ealm_main'"'"'|'"'"'-Wl,-e,alm_main'"'"', '"'"'-fuse-ld=bfd'"'"'|' src/SConscript
    fi
}

build() {
  cd "$srcdir/aocl-libm"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local amdclang="$(command -v "$CC")"
  local amdclangxx="$(command -v "$CXX")"

  scons -j"$(nproc)" \
    ALM_CC="${amdclang}" \
    ALM_CXX="${amdclangxx}" \
    --arch_config=avx512 \
    --aocl_utils_install_path=/usr \
    --aocl_utils_link=0
}

package() {
  cd "$srcdir/aocl-libm"

  install -dm755 "$pkgdir/usr/lib" "$pkgdir/usr/include"
  find build/aocl-release/src -name 'libalm*' -exec install -m755 {} "$pkgdir/usr/lib/" \;

  if [[ -f build/aocl-release/src/compat/glibc-compat.o ]]; then
    install -m644 build/aocl-release/src/compat/glibc-compat.o "$pkgdir/usr/lib/"
  fi

  if [[ -d include ]]; then
    cp -a include/. "$pkgdir/usr/include/"
  fi

  if [[ -f "$pkgdir/usr/lib/libalm.so" ]]; then
    patchelf --set-rpath /usr/lib "$pkgdir/usr/lib/libalm.so"
  fi
}
