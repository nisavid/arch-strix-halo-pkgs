prepare() {
  cd "$srcdir/Python-3.14.4"

  rm -r Modules/expat
  rm -r Modules/_decimal/libmpdec
}

build() {
  cd "$srcdir/Python-3.14.4"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local amdclang="$CC"
  local amdclangxx="$CXX"
  local _debug_prefix="/usr/src/debug/python-gfx1151"
  local _base_cflags="-march=native -O3 -pipe -fno-plt -fexceptions -Wp,-D_FORTIFY_SOURCE=3 -Wformat -Werror=format-security -fstack-clash-protection -fcf-protection -mpclmul -g -ffile-prefix-map=$srcdir=${_debug_prefix} -flto=auto -ffat-lto-objects -fno-semantic-interposition"

  unset CFLAGS CXXFLAGS LDFLAGS CMAKE_C_FLAGS_RELEASE CMAKE_CXX_FLAGS_RELEASE \
    CMAKE_EXE_LINKER_FLAGS CMAKE_SHARED_LINKER_FLAGS

  ./configure \
    --prefix="/usr" \
    --enable-shared \
    --with-computed-gotos \
    --enable-optimizations \
    --with-lto \
    --enable-ipv6 \
    --with-system-expat \
    --with-dbmliborder=gdbm:ndbm \
    --with-system-libmpdec \
    --enable-loadable-sqlite-extensions \
    --without-ensurepip \
    --with-tzpath=/usr/share/zoneinfo \
    CC="${amdclang}" \
    CXX="${amdclangxx}" \
    CFLAGS="${_base_cflags} -famd-opt -Wno-error=unused-command-line-argument" \
    CXXFLAGS="${_base_cflags} -famd-opt -Wno-error=unused-command-line-argument" \
    LDFLAGS="-Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,relro -Wl,-z,now -Wl,-z,pack-relative-relocs -flto=auto -fuse-ld=lld"

  make EXTRA_CFLAGS="${_base_cflags} -famd-opt -Wno-error=unused-command-line-argument" -j"$(nproc)"
}

package() {
  cd "$srcdir/Python-3.14.4"
  make DESTDIR="$pkgdir" install

  local _debug_prefix="/usr/src/debug/python-gfx1151"
  local _sanitized_src="${_debug_prefix}/Python-3.14.4"
  local _sysconfig="$pkgdir/usr/lib/python3.14/_sysconfigdata__linux_x86_64-linux-gnu.py"
  local _sysconfig_json="$pkgdir/usr/lib/python3.14/_sysconfig_vars__linux_x86_64-linux-gnu.json"
  local _config_makefile="$pkgdir/usr/lib/python3.14/config-3.14-x86_64-linux-gnu/Makefile"
  local _python_config="$pkgdir/usr/bin/python3.14-config"

  sed -i     -e "s|$srcdir/Python-3.14.4|${_sanitized_src}|g"     -e "s|$srcdir|${_debug_prefix}|g"     -e "s|/tmp/pkg/src/Python-3.14.4|${_sanitized_src}|g"     "${_sysconfig}" "${_sysconfig_json}" "${_config_makefile}" "${_python_config}"
  rm -f "$pkgdir/usr/lib/python3.14/__pycache__/_sysconfigdata__linux_x86_64-linux-gnu."*.pyc

  ln -sf python3 "$pkgdir/usr/bin/python"
  ln -sf python3-config "$pkgdir/usr/bin/python-config"
  ln -sf idle3 "$pkgdir/usr/bin/idle"
  ln -sf pydoc3 "$pkgdir/usr/bin/pydoc"
  ln -sf python3.14.1 "$pkgdir/usr/share/man/man1/python.1"

  install -dm755 "$pkgdir/usr/lib/python3.14/Tools/i18n" "$pkgdir/usr/lib/python3.14/Tools/scripts"
  install -m755 Tools/i18n/msgfmt.py Tools/i18n/pygettext.py "$pkgdir/usr/lib/python3.14/Tools/i18n/"
  install -m755 Tools/scripts/README Tools/scripts/*.py "$pkgdir/usr/lib/python3.14/Tools/scripts/"

  install -Dm644 /dev/stdin "$pkgdir/usr/lib/python3.14/EXTERNALLY-MANAGED" <<'EOF'
[externally-managed]
Error=To install Python packages system-wide, use pacman or a dedicated virtual environment.
EOF
}
