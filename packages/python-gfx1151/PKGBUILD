pkgver=3.14.4.r8.d20260317.gad42886
pkgrel=1
pkgdesc='The Python programming language rebuilt with amdclang for Strix Halo gfx1151'
arch=('x86_64')
url=https://www.python.org/
license=(PSF-2.0)
depends=(bzip2 expat gdbm libffi libnsl libxcrypt mpdecimal openssl tzdata zlib zstd)
makedepends=(bluez-libs gdb rocm-llvm-gfx1151 sqlite tk ttf-font xorg-server-xvfb xz)
optdepends=('python-setuptools: for building Python packages using tooling that is usually bundled with Python' 'python-pip: for installing Python packages using tooling that is usually bundled with Python' 'python-pipx: for installing Python software not packaged on Arch Linux' 'sqlite: for a default database integration' 'xz: for lzma' 'tk: for tkinter')
