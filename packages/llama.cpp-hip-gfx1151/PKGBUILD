pkgname=llama.cpp-hip-gfx1151
pkgver=b8992
pkgrel=1
pkgdesc='llama.cpp ROCm backend rebuilt for Strix Halo gfx1151'
arch=('x86_64')
url=https://github.com/ggml-org/llama.cpp
license=(MIT)
depends=(gcc-libs glibc hip-runtime-amd-gfx1151 rocm-core-gfx1151)
makedepends=(cmake ninja rocm-llvm-gfx1151)
optdepends=()
options=()
provides=(llama.cpp-hip-gfx1151 llama.cpp-hip)
conflicts=(llama.cpp-hip)
replaces=()
source=(llama.cpp-5cbfb18075c95437e4ac7fb50e3baf88fe137a87.tar.gz::https://github.com/ggml-org/llama.cpp/archive/5cbfb18075c95437e4ac7fb50e3baf88fe137a87.tar.gz)
sha256sums=(SKIP)

build() {
  cd "$srcdir/llama.cpp-5cbfb18075c95437e4ac7fb50e3baf88fe137a87"

  _setup_compiler_env() {
  local _compiler_root="/opt/rocm/lib/llvm/bin"
  local _ccache_dir="$srcdir/.ccache/bin"
  local _ccache_cache="$srcdir/.ccache/cache"
  if command -v ccache >/dev/null 2>&1; then
    mkdir -p "${_ccache_dir}" "${_ccache_cache}"
    local _ccache_bin _name
    _ccache_bin="$(command -v ccache)"
    for _name in clang clang++ clang-22 amdclang amdclang++ hipcc hipcc.pl gcc g++ cc c++; do
      ln -sf "${_ccache_bin}" "${_ccache_dir}/${_name}"
    done
    export PATH="${_ccache_dir}:$PATH"
    export CCACHE_BASEDIR="${CCACHE_BASEDIR:-$srcdir}"
    export CCACHE_DIR="${CCACHE_DIR:-${_ccache_cache}}"
    export CCACHE_NOCPP2=1
    export CCACHE_PATH="${_compiler_root}:/opt/rocm/bin:/usr/bin"
    export CC=amdclang
    export CXX=amdclang++
  else
    export CC="${_compiler_root}/amdclang"
    export CXX="${_compiler_root}/amdclang++"
  fi
}

  _setup_compiler_env
  local amdclang="$CC"
  local amdclangxx="$CXX"
  local build_root="$srcdir/build-hip"
  local install_root="/opt/llama.cpp-hip-gfx1151"
  local backend_cflags="-O3 -march=native -flto=thin -mprefer-vector-width=512 -famd-opt -Wno-error=unused-command-line-argument"
  local _debug_prefix="/usr/src/debug/llama.cpp-hip-gfx1151"
  local _debug_map="-ffile-prefix-map=$srcdir=${_debug_prefix}"
  local _linker_flags="-flto=thin -fuse-ld=lld"
  backend_cflags="${backend_cflags} ${_debug_map}"
  if [[ "hip" == "hip" ]]; then
    local _probe_src="$srcdir/.llama-hip-flag-probe.c"
    local _probe_obj="$srcdir/.llama-hip-flag-probe.o"
    local _aggressive_flags="-mllvm -polly -mllvm -polly-vectorizer=stripmine -mllvm -inline-threshold=600 -mllvm -unroll-threshold=150"
    printf '%s
' 'int main(void) { return 0; }' > "${_probe_src}"
    if "${amdclang}" -O2 -x c -c "${_probe_src}" -o "${_probe_obj}" ${_aggressive_flags} >/dev/null 2>&1; then
      backend_cflags="${backend_cflags} ${_aggressive_flags}"
    fi
    rm -f "${_probe_src}" "${_probe_obj}"
  fi

  rm -rf "${build_root}"

  cmake -B "${build_root}" -GNinja . \
    -DCMAKE_C_COMPILER="${amdclang}" \
    -DCMAKE_CXX_COMPILER="${amdclangxx}" \
    -DCMAKE_C_FLAGS="${backend_cflags}" \
    -DCMAKE_CXX_FLAGS="${backend_cflags}" \
    -DCMAKE_C_FLAGS_RELEASE="-DNDEBUG ${backend_cflags}" \
    -DCMAKE_CXX_FLAGS_RELEASE="-DNDEBUG ${backend_cflags}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="${install_root}" \
    -DCMAKE_CXX_CLANG_TIDY=/bin/true \
    -DGGML_HIP=ON \
    -DGGML_VULKAN=OFF \
    -DAMDGPU_TARGETS=gfx1151 \
    -DCMAKE_HIP_COMPILER=${amdclangxx} \
    "-DCMAKE_HIP_FLAGS=--offload-arch=gfx1151 -mllvm -amdgpu-function-calls=false -mllvm -amdgpu-early-inline-all=true -famd-opt ${_debug_map}" \
    "-DCMAKE_EXE_LINKER_FLAGS=${_linker_flags}" \
    "-DCMAKE_SHARED_LINKER_FLAGS=${_linker_flags}" \
    -DLLAMA_BUILD_SERVER=ON \
    -DLLAMA_BUILD_TOOLS=ON \
    -DLLAMA_BUILD_TESTS=OFF \
    -DLLAMA_BUILD_EXAMPLES=OFF

  cmake --build "${build_root}"
}

package() {
  cd "$srcdir/llama.cpp-5cbfb18075c95437e4ac7fb50e3baf88fe137a87"
  local build_root="$srcdir/build-hip"
  local install_root="/opt/llama.cpp-hip-gfx1151"

  DESTDIR="$pkgdir" cmake --install "${build_root}"
  rm -f "$pkgdir${install_root}/bin"/test-*
  if command -v patchelf >/dev/null 2>&1; then
    local _bin _libdir
    _libdir="/opt/llama.cpp-hip-gfx1151/lib"
    for _bin in "$pkgdir/opt/llama.cpp-hip-gfx1151/bin"/*; do
      [[ -f "${_bin}" ]] || continue
      patchelf --set-rpath "$_libdir" "${_bin}" 2>/dev/null || true
    done
  fi
  if [[ -d "$pkgdir/opt/llama.cpp-hip-gfx1151/bin" ]]; then
    local _backend_suffix="hip-gfx1151"
    local _tool _base
    for _tool in "$pkgdir/opt/llama.cpp-hip-gfx1151/bin"/*; do
      [[ -f "${_tool}" ]] || continue
      _base="$(basename "${_tool}")"
      install -Dm755 /dev/stdin "$pkgdir/usr/bin/${_base}-${_backend_suffix}" <<EOF
#!/usr/bin/env bash
exec /opt/llama.cpp-hip-gfx1151/bin/${_base} "\$@"
EOF
    done
  fi
  install -Dm644 "$srcdir/llama.cpp-5cbfb18075c95437e4ac7fb50e3baf88fe137a87/LICENSE" "$pkgdir/usr/share/licenses/llama.cpp-hip-gfx1151/LICENSE"
}
